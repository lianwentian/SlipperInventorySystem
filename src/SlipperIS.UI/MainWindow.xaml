<Window x:Class="SlipperIS.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="拖鞋库存管理系统" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <DockPanel>
        <!-- 菜单栏 -->
        <Menu DockPanel.Dock="Top" Background="#2D2D2D" Foreground="White" FontSize="12">
            <MenuItem Header="文件">
                <MenuItem Header="退出" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="产品">
                <MenuItem Header="产品列表" Click="Products_Click"/>
                <MenuItem Header="库存管理" Click="Stock_Click"/>
            </MenuItem>
            <MenuItem Header="销售">
                <MenuItem Header="销售订单" Click="SalesOrder_Click"/>
                <MenuItem Header="客户管理" Click="Customer_Click"/>
            </MenuItem>
            <MenuItem Header="报价">
                <MenuItem Header="报价单" Click="Quotation_Click"/>
            </MenuItem>
            <MenuItem Header="报表">
                <MenuItem Header="销售报表" Click="SalesReport_Click"/>
                <MenuItem Header="库存报表" Click="StockReport_Click"/>
            </MenuItem>
            <MenuItem Header="产品图片" Background="#4CAF50" Foreground="White">
                <MenuItem Header="图片预览" Click="ProductImage_Click"/>
            </MenuItem>
            <MenuItem Header="设置">
                <MenuItem Header="用户管理" Click="User_Click"/>
                <MenuItem Header="角色权限" Click="Role_Click"/>
            </MenuItem>
            <MenuItem Header="帮助">
                <MenuItem Header="关于" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <!-- 标题栏 -->
        <Border DockPanel.Dock="Top" Background="#2196F3" Height="50" Padding="20,0">
            <TextBlock Text="拖鞋库存管理系统 v1.0" Foreground="White" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>
        </Border>

        <!-- 主内容区 -->
        <Border DockPanel.Dock="Top" Background="White" Margin="10">
            <StackPanel Margin="20">
                <TextBlock Text="欢迎使用拖鞋库存管理系统" FontSize="16" FontWeight="Bold" Foreground="#333"/>
                <TextBlock Text="系统主要功能：" FontSize="12" Margin="0,10,0,5" Foreground="#666"/>
                <ItemsControl Margin="20,0,0,0">
                    <TextBlock Text="• 产品和库存管理" Foreground="#666"/>
                    <TextBlock Text="• 销售订单管理" Foreground="#666"/>
                    <TextBlock Text="• 报价单生成" Foreground="#666"/>
                    <TextBlock Text="• 产品图片预览" Foreground="#666"/>
                    <TextBlock Text="• 报表分析和导出" Foreground="#666"/>
                    <TextBlock Text="• 用户和权限管理" Foreground="#666"/>
                </ItemsControl>
                <TextBlock Text="请使用菜单栏导航到各功能模块。" FontSize="12" Margin="0,10,0,0" Foreground="#999"/>
            </StackPanel>
        </Border>
    </DockPanel>
</Window>
