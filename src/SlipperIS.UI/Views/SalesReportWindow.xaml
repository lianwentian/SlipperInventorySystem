<Window x:Class="SlipperIS.UI.Views.SalesReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="销售报表" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 筛选栏 -->
        <Border Grid.Row="0" Background="White" Margin="8,8,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="开始日期：" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#555"/>
                <DatePicker x:Name="DpStart" Width="120" Height="28" BorderBrush="#CCC" BorderThickness="1"/>
                <TextBlock Text="结束日期：" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="#555"/>
                <DatePicker x:Name="DpEnd" Width="120" Height="28" BorderBrush="#CCC" BorderThickness="1"/>
                <Button Content="查询" Margin="8,0,0,0" Padding="12,4"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Query_Click"/>
                <Button Content="重置" Margin="4,0,0,0" Padding="8,4"
                        Background="#9E9E9E" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Reset_Click"/>
            </StackPanel>
        </Border>

        <!-- 汇总统计卡片 -->
        <Grid Grid.Row="1" Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2196F3" CornerRadius="4" Margin="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="总订单数" Foreground="White" FontSize="12" Opacity="0.8"/>
                    <TextBlock x:Name="TxtTotalOrders" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="笔" Foreground="White" FontSize="11" Opacity="0.8"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Background="#4CAF50" CornerRadius="4" Margin="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="销售总额" Foreground="White" FontSize="12" Opacity="0.8"/>
                    <TextBlock x:Name="TxtTotalAmount" Text="¥0.00" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="元" Foreground="White" FontSize="11" Opacity="0.8"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="2" Background="#FF9800" CornerRadius="4" Margin="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="平均订单金额" Foreground="White" FontSize="12" Opacity="0.8"/>
                    <TextBlock x:Name="TxtAvgAmount" Text="¥0.00" Foreground="White" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="元" Foreground="White" FontSize="11" Opacity="0.8"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="3" Background="#9C27B0" CornerRadius="4" Margin="4" Padding="12">
                <StackPanel>
                    <TextBlock Text="客户数量" Foreground="White" FontSize="12" Opacity="0.8"/>
                    <TextBlock x:Name="TxtCustomerCount" Text="0" Foreground="White" FontSize="28" FontWeight="Bold"/>
                    <TextBlock Text="位" Foreground="White" FontSize="11" Opacity="0.8"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 订单明细列表 -->
        <DataGrid x:Name="ReportGrid" Grid.Row="2"
                  Margin="8,4" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="120"/>
                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="140"/>
                <DataGridTextColumn Header="订单日期" Binding="{Binding OrderDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="总金额" Binding="{Binding TotalAmount, StringFormat=\{0:F2\}}" Width="100"/>
                <DataGridTextColumn Header="最终金额" Binding="{Binding FinalAmount, StringFormat=\{0:F2\}}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="付款状态" Binding="{Binding PaymentStatus}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部栏 -->
        <Border Grid.Row="3" Background="White" Margin="8,4,8,8" Padding="8,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock x:Name="StatusText" VerticalAlignment="Center" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
