<Window x:Class="SlipperIS.UI.Views.SalesReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="销售报表" Height="620" Width="950"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 查询条件 -->
        <Border DockPanel.Dock="Top" Background="#37474F" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="开始日期：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <DatePicker x:Name="StartDatePicker" Width="120" VerticalAlignment="Center"/>
                <TextBlock Text="结束日期：" Foreground="White" VerticalAlignment="Center" Margin="15,0,5,0"/>
                <DatePicker x:Name="EndDatePicker" Width="120" VerticalAlignment="Center"/>
                <Button Content="🔍 查询" Click="Query_Click" Background="#2196F3" Foreground="White"
                        Padding="15,5" Margin="15,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 汇总统计 -->
        <Border DockPanel.Dock="Top" Background="#E3F2FD" Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <Border Background="#2196F3" CornerRadius="4" Padding="15,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="总订单数" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalOrdersText" Text="0" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#4CAF50" CornerRadius="4" Padding="15,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="总销售额" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalAmountText" Text="0.00" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#FF9800" CornerRadius="4" Padding="15,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="平均订单额" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="AvgAmountText" Text="0.00" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#9C27B0" CornerRadius="4" Padding="15,8">
                    <StackPanel>
                        <TextBlock Text="客户数" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="CustomerCountText" Text="0" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 订单列表 -->
        <DataGrid x:Name="ReportGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="130"/>
                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="150"/>
                <DataGridTextColumn Header="下单日期" Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="金额" Binding="{Binding FinalAmount, StringFormat={}{0:F2}}" Width="100"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="付款状态" Binding="{Binding PaymentStatus}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
