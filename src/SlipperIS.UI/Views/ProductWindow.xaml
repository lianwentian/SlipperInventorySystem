<Window x:Class="SlipperIS.UI.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品管理" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 搜索栏 -->
        <Border Grid.Row="0" Background="White" Margin="8,8,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#555"/>
                <TextBox x:Name="SearchBox" Width="200" Height="28" Padding="4,2"
                         BorderBrush="#CCC" BorderThickness="1"
                         TextChanged="SearchBox_TextChanged"
                         VerticalContentAlignment="Center"/>
                <Button Content="刷新" Margin="8,0,0,0" Padding="8,4"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- 产品列表 -->
        <DataGrid x:Name="ProductGrid" Grid.Row="1"
                  Margin="8,4" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1"
                  SelectionChanged="ProductGrid_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="产品编码" Binding="{Binding ProductCode}" Width="100"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="90"/>
                <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="120"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="成本价" Binding="{Binding CostPrice, StringFormat=\{0:F2\}}" Width="80"/>
                <DataGridTextColumn Header="销售价" Binding="{Binding SalesPrice, StringFormat=\{0:F2\}}" Width="80"/>
                <DataGridTextColumn Header="VIP价" Binding="{Binding VipPrice, StringFormat=\{0:F2\}}" Width="80"/>
                <DataGridTextColumn Header="库存数量" Binding="{Binding StockQuantity}" Width="80"/>
                <DataGridTextColumn Header="最低库存" Binding="{Binding MinStockLevel}" Width="80"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 编辑表单 -->
        <Border x:Name="EditPanel" Grid.Row="2" Visibility="Collapsed"
                Background="White" Margin="8,4" Padding="12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="EditTitle" Text="添加产品" FontWeight="Bold"
                           FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 第一行 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="产品编码 *" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtProductCode" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="产品名称 *" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtProductName" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="类别" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtCategory" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="4">
                        <TextBlock Text="规格" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtSpecification" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>

                    <!-- 第二行 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="单位" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtUnit" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="Pair"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                        <TextBlock Text="成本价" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtCostPrice" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                        <TextBlock Text="销售价" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtSalesPrice" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="4">
                        <TextBlock Text="VIP价" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtVipPrice" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="0"/>
                    </StackPanel>

                    <!-- 第三行 -->
                    <StackPanel Grid.Row="2" Grid.Column="0" Margin="4">
                        <TextBlock Text="库存数量" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtStockQty" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="1" Margin="4">
                        <TextBlock Text="最低库存" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtMinStock" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1" Text="10"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="2" Margin="4">
                        <TextBlock Text="描述" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtDescription" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="2" Grid.Column="3" Margin="4" VerticalAlignment="Bottom">
                        <CheckBox x:Name="ChkIsActive" Content="启用" IsChecked="True" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 表单操作按钮 -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="保存" Padding="16,6" Margin="0,0,8,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="SaveProduct_Click"/>
                    <Button Content="取消" Padding="16,6"
                            Background="#9E9E9E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="CancelEdit_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作按钮栏 -->
        <Border Grid.Row="3" Background="White" Margin="8,4,8,8" Padding="8,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="➕ 添加" Padding="12,6" Margin="0,0,8,0"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="AddProduct_Click"/>
                <Button Content="✏️ 编辑" Padding="12,6" Margin="0,0,8,0"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="EditProduct_Click"/>
                <Button Content="🗑️ 删除" Padding="12,6"
                        Background="#F44336" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="DeleteProduct_Click"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Margin="16,0,0,0" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
