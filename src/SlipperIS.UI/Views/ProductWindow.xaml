<Window x:Class="SlipperIS.UI.Views.ProductWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品管理" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 添加产品" Click="AddProduct_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✏️ 编辑" Click="EditProduct_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 删除" Click="DeleteProduct_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="搜索：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="200" Padding="5,3" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 数据表格 -->
        <DataGrid x:Name="ProductGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="产品代码" Binding="{Binding ProductCode}" Width="90"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80"/>
                <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="120"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="成本价" Binding="{Binding CostPrice, StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="销售价" Binding="{Binding SalesPrice, StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="VIP价" Binding="{Binding VipPrice, StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="库存数量" Binding="{Binding StockQuantity}" Width="80"/>
                <DataGridTextColumn Header="最低库存" Binding="{Binding MinStockLevel}" Width="80"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
