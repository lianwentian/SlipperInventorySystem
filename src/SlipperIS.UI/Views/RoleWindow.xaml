<Window x:Class="SlipperIS.UI.Views.RoleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="角色权限管理" Height="580" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 创建角色" Click="AddRole_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✏️ 编辑" Click="EditRole_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 删除" Click="DeleteRole_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🔑 分配权限" Click="AssignPermissions_Click" Background="#9C27B0" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <DataGrid x:Name="RoleGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="角色名称" Binding="{Binding Name}" Width="150"/>
                <DataGridTextColumn Header="描述" Binding="{Binding Description}" Width="250"/>
                <DataGridTextColumn Header="用户数量" Binding="{Binding UserCount}" Width="100"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAt, StringFormat=yyyy-MM-dd}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
