<Window x:Class="SlipperIS.UI.Views.SalesOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="销售订单" Height="620" Width="1050"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 新建订单" Click="NewOrder_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="👁️ 查看详情" Click="ViewOrder_Click" Background="#2196F3" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 取消订单" Click="CancelOrder_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="状态过滤：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="StatusFilter" Width="110" Padding="5,3" VerticalAlignment="Center"
                          SelectionChanged="StatusFilter_SelectionChanged">
                    <ComboBoxItem Content="全部" IsSelected="True"/>
                    <ComboBoxItem Content="Pending"/>
                    <ComboBoxItem Content="Confirmed"/>
                    <ComboBoxItem Content="Shipped"/>
                    <ComboBoxItem Content="Completed"/>
                    <ComboBoxItem Content="Cancelled"/>
                </ComboBox>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 订单列表 -->
        <DataGrid x:Name="OrderGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="订单号" Binding="{Binding OrderNumber}" Width="130"/>
                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="150"/>
                <DataGridTextColumn Header="下单日期" Binding="{Binding OrderDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="交货日期" Binding="{Binding DeliveryDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="金额" Binding="{Binding FinalAmount, StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="付款状态" Binding="{Binding PaymentStatus}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
