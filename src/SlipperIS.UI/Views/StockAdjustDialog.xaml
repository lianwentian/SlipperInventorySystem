<Window x:Class="SlipperIS.UI.Views.StockAdjustDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="260" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="确定" Click="Ok_Click" Background="#2196F3" Foreground="White"
                    Padding="20,7" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Click="Cancel_Click" Padding="20,7" Cursor="Hand"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="产品" VerticalAlignment="Center" Margin="0,8"/>
            <TextBlock x:Name="ProductNameText" Grid.Row="0" Grid.Column="1" Margin="0,8" FontWeight="Bold"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="当前库存" VerticalAlignment="Center" Margin="0,8"/>
            <TextBlock x:Name="CurrentStockText" Grid.Row="1" Grid.Column="1" Margin="0,8"/>

            <TextBlock x:Name="QuantityLabel" Grid.Row="2" Grid.Column="0" Text="数量 *" VerticalAlignment="Center" Margin="0,8"/>
            <TextBox x:Name="QuantityBox" Grid.Row="2" Grid.Column="1" Margin="0,8" Padding="5,3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="原因" VerticalAlignment="Center" Margin="0,8"/>
            <TextBox x:Name="ReasonBox" Grid.Row="3" Grid.Column="1" Margin="0,8" Padding="5,3"/>
        </Grid>
    </DockPanel>
</Window>
