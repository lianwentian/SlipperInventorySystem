<Window x:Class="SlipperIS.UI.Views.UserEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户信息" Height="380" Width="380"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Click="Save_Click" Background="#2196F3" Foreground="White"
                    Padding="20,7" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Click="Cancel_Click" Padding="20,7" Cursor="Hand"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="用户名 *" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox x:Name="UsernameBox" Grid.Row="0" Grid.Column="1" Margin="0,6" Padding="5,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="密码 *" VerticalAlignment="Center" Margin="0,6"/>
            <PasswordBox x:Name="PasswordBox" Grid.Row="1" Grid.Column="1" Margin="0,6" Padding="5,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="全名" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox x:Name="FullNameBox" Grid.Row="2" Grid.Column="1" Margin="0,6" Padding="5,3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="邮箱" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox x:Name="EmailBox" Grid.Row="3" Grid.Column="1" Margin="0,6" Padding="5,3"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="电话" VerticalAlignment="Center" Margin="0,6"/>
            <TextBox x:Name="PhoneBox" Grid.Row="4" Grid.Column="1" Margin="0,6" Padding="5,3"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="角色 *" VerticalAlignment="Center" Margin="0,6"/>
            <ComboBox x:Name="RoleCombo" Grid.Row="5" Grid.Column="1" Margin="0,6" Padding="5,3"
                      DisplayMemberPath="Name" SelectedValuePath="Id"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="启用" VerticalAlignment="Center" Margin="0,6"/>
            <CheckBox x:Name="ActiveCheck" Grid.Row="6" Grid.Column="1" Margin="0,6" VerticalAlignment="Center"
                      IsChecked="True"/>
        </Grid>
    </DockPanel>
</Window>
