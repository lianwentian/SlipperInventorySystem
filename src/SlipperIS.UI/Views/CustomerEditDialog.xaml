<Window x:Class="SlipperIS.UI.Views.CustomerEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="客户信息" Height="430" Width="400"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="15">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="保存" Click="Save_Click" Background="#2196F3" Foreground="White"
                    Padding="20,7" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="取消" Click="Cancel_Click" Padding="20,7" Cursor="Hand"/>
        </StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="90"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="客户编码 *" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="CodeBox" Grid.Row="0" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="1" Grid.Column="0" Text="客户名称 *" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="NameBox" Grid.Row="1" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="2" Grid.Column="0" Text="联系人" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="ContactBox" Grid.Row="2" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="3" Grid.Column="0" Text="电话" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="PhoneBox" Grid.Row="3" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="4" Grid.Column="0" Text="邮箱" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="EmailBox" Grid.Row="4" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="5" Grid.Column="0" Text="城市" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="CityBox" Grid.Row="5" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="6" Grid.Column="0" Text="地址" VerticalAlignment="Center" Margin="0,5"/>
            <TextBox x:Name="AddressBox" Grid.Row="6" Grid.Column="1" Margin="0,5" Padding="5,3"/>

            <TextBlock Grid.Row="7" Grid.Column="0" Text="VIP客户" VerticalAlignment="Center" Margin="0,5"/>
            <CheckBox x:Name="VipCheck" Grid.Row="7" Grid.Column="1" Margin="0,5" VerticalAlignment="Center"/>

            <TextBlock Grid.Row="8" Grid.Column="0" Text="启用" VerticalAlignment="Center" Margin="0,5"/>
            <CheckBox x:Name="ActiveCheck" Grid.Row="8" Grid.Column="1" Margin="0,5" VerticalAlignment="Center"
                      IsChecked="True"/>
        </Grid>
    </DockPanel>
</Window>
