<Window x:Class="SlipperIS.UI.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="客户管理" Height="560" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 添加客户" Click="AddCustomer_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✏️ 编辑" Click="EditCustomer_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 删除" Click="DeleteCustomer_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="搜索：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="200" Padding="5,3" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <DataGrid x:Name="CustomerGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="客户编码" Binding="{Binding CustomerCode}" Width="90"/>
                <DataGridTextColumn Header="客户名称" Binding="{Binding CustomerName}" Width="160"/>
                <DataGridTextColumn Header="联系人" Binding="{Binding ContactPerson}" Width="90"/>
                <DataGridTextColumn Header="电话" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="150"/>
                <DataGridTextColumn Header="城市" Binding="{Binding City}" Width="90"/>
                <DataGridCheckBoxColumn Header="VIP" Binding="{Binding IsVip}" Width="50"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
