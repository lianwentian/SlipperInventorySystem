<Window x:Class="SlipperIS.UI.Views.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="客户管理" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 搜索栏 -->
        <Border Grid.Row="0" Background="White" Margin="8,8,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#555"/>
                <TextBox x:Name="SearchBox" Width="200" Height="28" Padding="4,2"
                         BorderBrush="#CCC" BorderThickness="1" VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="刷新" Margin="8,0,0,0" Padding="8,4"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- 客户列表 -->
        <DataGrid x:Name="CustomerGrid" Grid.Row="1"
                  Margin="8,4" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="客户编码" Binding="{Binding CustomerCode}" Width="90"/>
                <DataGridTextColumn Header="客户名称" Binding="{Binding CustomerName}" Width="150"/>
                <DataGridTextColumn Header="联系人" Binding="{Binding ContactPerson}" Width="90"/>
                <DataGridTextColumn Header="电话" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="160"/>
                <DataGridTextColumn Header="城市" Binding="{Binding City}" Width="80"/>
                <DataGridTextColumn Header="区域" Binding="{Binding District}" Width="80"/>
                <DataGridCheckBoxColumn Header="VIP" Binding="{Binding IsVip}" Width="50"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="50"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 编辑表单 -->
        <Border x:Name="EditPanel" Grid.Row="2" Visibility="Collapsed"
                Background="White" Margin="8,4" Padding="12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock x:Name="EditTitle" Text="添加客户" FontWeight="Bold"
                           FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 第一行 -->
                    <StackPanel Grid.Row="0" Grid.Column="0" Margin="4">
                        <TextBlock Text="客户编码 *" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtCode" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="4">
                        <TextBlock Text="客户名称 *" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtName" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="4">
                        <TextBlock Text="联系人" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtContact" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="0" Grid.Column="3" Margin="4">
                        <TextBlock Text="电话" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtPhone" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>

                    <!-- 第二行 -->
                    <StackPanel Grid.Row="1" Grid.Column="0" Margin="4">
                        <TextBlock Text="邮箱" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtEmail" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="1" Margin="4">
                        <TextBlock Text="城市" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtCity" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="2" Margin="4">
                        <TextBlock Text="地址" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtAddress" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Row="1" Grid.Column="3" Margin="4" VerticalAlignment="Bottom">
                        <CheckBox x:Name="ChkVip" Content="VIP 客户" Margin="0,4,0,0"/>
                        <CheckBox x:Name="ChkActive" Content="启用" IsChecked="True" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="保存" Padding="16,6" Margin="0,0,8,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="SaveCustomer_Click"/>
                    <Button Content="取消" Padding="16,6"
                            Background="#9E9E9E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="CancelEdit_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作按钮栏 -->
        <Border Grid.Row="3" Background="White" Margin="8,4,8,8" Padding="8,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="➕ 添加" Padding="12,6" Margin="0,0,8,0"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="AddCustomer_Click"/>
                <Button Content="✏️ 编辑" Padding="12,6" Margin="0,0,8,0"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="EditCustomer_Click"/>
                <Button Content="🗑️ 删除" Padding="12,6"
                        Background="#F44336" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="DeleteCustomer_Click"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Margin="16,0,0,0" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
