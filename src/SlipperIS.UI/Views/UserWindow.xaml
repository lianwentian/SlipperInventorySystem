<Window x:Class="SlipperIS.UI.Views.UserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="用户管理" Height="540" Width="850"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 创建用户" Click="AddUser_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="✏️ 编辑" Click="EditUser_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 删除" Click="DeleteUser_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="搜索：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="200" Padding="5,3" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <DataGrid x:Name="UserGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="用户名" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="全名" Binding="{Binding FullName}" Width="140"/>
                <DataGridTextColumn Header="邮箱" Binding="{Binding Email}" Width="170"/>
                <DataGridTextColumn Header="电话" Binding="{Binding PhoneNumber}" Width="120"/>
                <DataGridTextColumn Header="角色" Binding="{Binding RoleName}" Width="100"/>
                <DataGridCheckBoxColumn Header="启用" Binding="{Binding IsActive}" Width="60"/>
                <DataGridTextColumn Header="最后登录" Binding="{Binding LastLoginAt, StringFormat=yyyy-MM-dd HH:mm}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
