<Window x:Class="SlipperIS.UI.Views.QuotationEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="报价单" Height="620" Width="800"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="SaveBtn" Content="保存" Click="Save_Click" Background="#2196F3" Foreground="White"
                    Padding="20,7" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
            <Button Content="关闭" Click="Close_Click" Padding="20,7" Cursor="Hand"/>
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="客户 *：" Width="70" VerticalAlignment="Center"/>
                    <ComboBox x:Name="CustomerCombo" Width="200" Padding="5,3"
                              DisplayMemberPath="CustomerName" SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Margin="10,5">
                    <TextBlock Text="报价单号：" Width="70" VerticalAlignment="Center"/>
                    <TextBlock x:Name="QuotationNumberText" VerticalAlignment="Center" FontWeight="Bold"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="报价日期：" Width="70" VerticalAlignment="Center"/>
                    <DatePicker x:Name="QuotationDatePicker" Width="140"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="10,5">
                    <TextBlock Text="有效期至：" Width="70" VerticalAlignment="Center"/>
                    <DatePicker x:Name="ValidUntilPicker" Width="140"/>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="0" Orientation="Horizontal" Margin="0,5">
                    <TextBlock Text="状态：" Width="70" VerticalAlignment="Center"/>
                    <ComboBox x:Name="StatusCombo" Width="140" Padding="5,3">
                        <ComboBoxItem Content="Draft" IsSelected="True"/>
                        <ComboBoxItem Content="Sent"/>
                        <ComboBoxItem Content="Accepted"/>
                        <ComboBoxItem Content="Rejected"/>
                        <ComboBoxItem Content="Converted"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="10,5">
                    <TextBlock Text="备注：" Width="70" VerticalAlignment="Center"/>
                    <TextBox x:Name="RemarksBox" Width="260" Padding="5,3"/>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" BorderBrush="#DDD" BorderThickness="1" Margin="0,5">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#F5F5F5" Padding="5">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="➕ 添加行" Click="AddLine_Click" Background="#4CAF50" Foreground="White"
                                    Padding="8,4" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                            <Button Content="🗑️ 删除行" Click="DeleteLine_Click" Background="#F44336" Foreground="White"
                                    Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                        </StackPanel>
                    </Border>
                    <DataGrid x:Name="DetailGrid" AutoGenerateColumns="False"
                              GridLinesVisibility="Horizontal" RowHeight="30" HeadersVisibility="Column"
                              SelectionMode="Single" CanUserAddRows="False">
                        <DataGrid.Columns>
                            <DataGridComboBoxColumn Header="产品" Width="180"
                                                    SelectedValueBinding="{Binding ProductId}"
                                                    DisplayMemberPath="ProductName"
                                                    SelectedValuePath="Id"/>
                            <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="70"/>
                            <DataGridTextColumn Header="单价" Binding="{Binding UnitPrice, StringFormat={}{0:F2}}" Width="90"/>
                            <DataGridTextColumn Header="折扣%" Binding="{Binding DiscountPercentage, StringFormat={}{0:F1}}" Width="70"/>
                            <DataGridTextColumn Header="行金额" Binding="{Binding LineAmount, StringFormat={}{0:F2}}" Width="90"/>
                            <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </Border>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,5">
                <TextBlock Text="合计金额：" FontWeight="Bold" VerticalAlignment="Center"/>
                <TextBlock x:Name="TotalText" FontWeight="Bold" FontSize="16" Foreground="#2196F3"
                           VerticalAlignment="Center" Margin="5,0,0,0"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
