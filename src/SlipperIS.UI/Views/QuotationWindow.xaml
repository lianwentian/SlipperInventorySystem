<Window x:Class="SlipperIS.UI.Views.QuotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="报价单管理" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="➕ 新建报价单" Click="NewQuotation_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="👁️ 查看详情" Click="ViewQuotation_Click" Background="#2196F3" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🔄 转为销售订单" Click="ConvertToOrder_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="🗑️ 删除" Click="DeleteQuotation_Click" Background="#F44336" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="状态过滤：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="StatusFilter" Width="100" Padding="5,3" VerticalAlignment="Center"
                          SelectionChanged="StatusFilter_SelectionChanged">
                    <ComboBoxItem Content="全部" IsSelected="True"/>
                    <ComboBoxItem Content="Draft"/>
                    <ComboBoxItem Content="Sent"/>
                    <ComboBoxItem Content="Accepted"/>
                    <ComboBoxItem Content="Rejected"/>
                    <ComboBoxItem Content="Converted"/>
                </ComboBox>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>
        <DataGrid x:Name="QuotationGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.Columns>
                <DataGridTextColumn Header="报价单号" Binding="{Binding QuotationNumber}" Width="130"/>
                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="160"/>
                <DataGridTextColumn Header="报价日期" Binding="{Binding QuotationDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="有效期至" Binding="{Binding ValidUntilDate, StringFormat=yyyy-MM-dd}" Width="100"/>
                <DataGridTextColumn Header="金额" Binding="{Binding FinalAmount, StringFormat={}{0:F2}}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="90"/>
                <DataGridTextColumn Header="已转订单" Binding="{Binding ConvertedOrderId}" Width="90"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
