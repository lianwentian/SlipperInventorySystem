<Window x:Class="SlipperIS.UI.Views.QuotationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="报价单管理" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 搜索栏 -->
        <Border Grid.Row="0" Background="White" Margin="8,8,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#555"/>
                <TextBox x:Name="SearchBox" Width="160" Height="28" Padding="4,2"
                         BorderBrush="#CCC" BorderThickness="1" VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <TextBlock Text="状态：" VerticalAlignment="Center" Margin="12,0,4,0" Foreground="#555"/>
                <ComboBox x:Name="CmbStatus" Width="100" Height="28" BorderBrush="#CCC" BorderThickness="1"
                          SelectionChanged="CmbStatus_SelectionChanged">
                    <ComboBoxItem Content="全部" IsSelected="True"/>
                    <ComboBoxItem Content="Draft"/>
                    <ComboBoxItem Content="Sent"/>
                    <ComboBoxItem Content="Accepted"/>
                    <ComboBoxItem Content="Rejected"/>
                </ComboBox>
                <Button Content="刷新" Margin="8,0,0,0" Padding="8,4"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- 报价单列表 -->
        <DataGrid x:Name="QuotationGrid" Grid.Row="1"
                  Margin="8,4" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1">
            <DataGrid.Columns>
                <DataGridTextColumn Header="报价单号" Binding="{Binding QuotationNumber}" Width="120"/>
                <DataGridTextColumn Header="客户" Binding="{Binding CustomerName}" Width="140"/>
                <DataGridTextColumn Header="报价日期" Binding="{Binding QuotationDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="有效期至" Binding="{Binding ValidUntilDate, StringFormat=\{0:yyyy-MM-dd\}}" Width="100"/>
                <DataGridTextColumn Header="总金额" Binding="{Binding TotalAmount, StringFormat=\{0:F2\}}" Width="90"/>
                <DataGridTextColumn Header="最终金额" Binding="{Binding FinalAmount, StringFormat=\{0:F2\}}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80"/>
                <DataGridTextColumn Header="备注" Binding="{Binding Remarks}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 新建报价单表单 -->
        <Border x:Name="NewQuotePanel" Grid.Row="2" Visibility="Collapsed"
                Background="White" Margin="8,4" Padding="12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="新建报价单" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="客户 *" Foreground="#555" FontSize="11"/>
                        <ComboBox x:Name="CmbCustomer" Height="28" Margin="0,2,0,0"
                                  BorderBrush="#CCC" BorderThickness="1"
                                  DisplayMemberPath="CustomerName"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="有效期至" Foreground="#555" FontSize="11"/>
                        <DatePicker x:Name="DpValidUntil" Height="28" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="备注" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtRemarks" Height="28" Padding="4,2" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="4" VerticalAlignment="Bottom">
                        <CheckBox x:Name="ChkShowDiscount" Content="显示折扣" IsChecked="True" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- 报价明细 -->
                <TextBlock Text="报价明细：" FontWeight="Bold" Margin="4,8,4,4" Foreground="#555"/>
                <DataGrid x:Name="DetailGrid" Height="120" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True"
                          SelectionMode="Single" GridLinesVisibility="Horizontal"
                          BorderBrush="#DDD" BorderThickness="1">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="产品" Binding="{Binding ProductName}" Width="*"/>
                        <DataGridTextColumn Header="数量" Binding="{Binding Quantity}" Width="70"/>
                        <DataGridTextColumn Header="单价" Binding="{Binding UnitPrice, StringFormat=\{0:F2\}}" Width="80"/>
                        <DataGridTextColumn Header="折扣%" Binding="{Binding DiscountPercentage, StringFormat=\{0:F1\}}" Width="70"/>
                        <DataGridTextColumn Header="金额" Binding="{Binding LineAmount, StringFormat=\{0:F2\}}" Width="90"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- 添加明细行 -->
                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                    <ComboBox x:Name="CmbProduct" Width="180" Height="28" BorderBrush="#CCC" BorderThickness="1"
                              DisplayMemberPath="ProductName" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtQty" Width="60" Height="28" Padding="4,2" Text="1"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtUnitPrice" Width="80" Height="28" Padding="4,2" Text="0"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtDiscount" Width="60" Height="28" Padding="4,2" Text="0"
                             BorderBrush="#CCC" BorderThickness="1" Margin="0,0,4,0"/>
                    <Button Content="添加" Padding="8,4" Margin="0,0,4,0"
                            Background="#607D8B" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="AddDetailLine_Click"/>
                    <Button Content="删除" Padding="8,4"
                            Background="#F44336" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="RemoveDetailLine_Click"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <TextBlock x:Name="TxtQuoteTotal" Text="合计：¥0.00" VerticalAlignment="Center"
                               FontWeight="Bold" Margin="0,0,16,0" Foreground="#333"/>
                    <Button Content="保存报价单" Padding="16,6" Margin="0,0,8,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="SaveQuotation_Click"/>
                    <Button Content="取消" Padding="16,6"
                            Background="#9E9E9E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="CancelQuotation_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作按钮栏 -->
        <Border Grid.Row="3" Background="White" Margin="8,4,8,8" Padding="8,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="➕ 新建报价单" Padding="12,6" Margin="0,0,8,0"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="NewQuotation_Click"/>
                <Button Content="📤 发送报价" Padding="12,6" Margin="0,0,8,0"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="SendQuotation_Click"/>
                <Button Content="🔄 转为订单" Padding="12,6"
                        Background="#9C27B0" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="ConvertToOrder_Click"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Margin="16,0,0,0" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
