<Window x:Class="SlipperIS.UI.Views.StockReportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="库存报表" Height="580" Width="900"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Background="#37474F" Padding="10,8">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="分类过滤：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="CategoryFilter" Width="140" Padding="5,3" VerticalAlignment="Center"
                          SelectionChanged="CategoryFilter_SelectionChanged"/>
                <CheckBox x:Name="LowStockOnly" Content="仅显示低库存" Foreground="White"
                          VerticalAlignment="Center" Margin="15,0,0,0"
                          Checked="Filter_Changed" Unchecked="Filter_Changed"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="15,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 汇总 -->
        <Border DockPanel.Dock="Top" Background="#E8F5E9" Padding="15,10">
            <StackPanel Orientation="Horizontal">
                <Border Background="#4CAF50" CornerRadius="4" Padding="15,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="产品总数" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalProductsText" Text="0" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#F44336" CornerRadius="4" Padding="15,8" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="低库存产品" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="LowStockCountText" Text="0" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
                <Border Background="#2196F3" CornerRadius="4" Padding="15,8">
                    <StackPanel>
                        <TextBlock Text="库存总价值" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock x:Name="TotalValueText" Text="0.00" Foreground="White" FontSize="20"
                                   FontWeight="Bold" HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Border>

        <!-- 数据表 -->
        <DataGrid x:Name="StockReportGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                            <Setter Property="Background" Value="#FFEBEE"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="产品代码" Binding="{Binding ProductCode}" Width="90"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80"/>
                <DataGridTextColumn Header="当前库存" Binding="{Binding StockQuantity}" Width="90"/>
                <DataGridTextColumn Header="最低库存" Binding="{Binding MinStockLevel}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding StockStatus}" Width="100"/>
                <DataGridTextColumn Header="成本价" Binding="{Binding CostPrice, StringFormat={}{0:F2}}" Width="80"/>
                <DataGridTextColumn Header="库存价值" Binding="{Binding StockValue, StringFormat={}{0:F2}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
