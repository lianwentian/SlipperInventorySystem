<Window x:Class="SlipperIS.UI.Views.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="库存管理" Height="600" Width="950"
        WindowStartupLocation="CenterScreen">
    <DockPanel>
        <!-- 工具栏 -->
        <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
            <StackPanel Orientation="Horizontal">
                <Button Content="📦 入库" Click="StockIn_Click" Background="#4CAF50" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="📤 出库" Click="StockOut_Click" Background="#FF9800" Foreground="White"
                        Padding="10,5" Margin="0,0,5,0" BorderThickness="0" Cursor="Hand"/>
                <Button Content="⚙️ 调整库存" Click="AdjustStock_Click" Background="#9C27B0" Foreground="White"
                        Padding="10,5" Margin="0,0,15,0" BorderThickness="0" Cursor="Hand"/>
                <TextBlock Text="搜索产品：" Foreground="White" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="SearchBox" Width="200" Padding="5,3" VerticalAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <Button Content="🔄 刷新" Click="Refresh_Click" Background="#607D8B" Foreground="White"
                        Padding="10,5" Margin="5,0,0,0" BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Border>

        <!-- 低库存提示 -->
        <Border x:Name="LowStockBanner" DockPanel.Dock="Top" Background="#FFF3E0" Padding="10,5"
                Visibility="Collapsed">
            <TextBlock x:Name="LowStockText" Foreground="#E65100" FontWeight="Bold"/>
        </Border>

        <!-- 数据表格 -->
        <DataGrid x:Name="StockGrid" AutoGenerateColumns="False" IsReadOnly="True"
                  AlternatingRowBackground="#F5F5F5" GridLinesVisibility="Horizontal"
                  SelectionMode="Single" CanUserSortColumns="True"
                  RowHeight="30" HeadersVisibility="Column">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="产品代码" Binding="{Binding ProductCode}" Width="90"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="150"/>
                <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="120"/>
                <DataGridTextColumn Header="单位" Binding="{Binding Unit}" Width="60"/>
                <DataGridTextColumn Header="当前库存" Binding="{Binding StockQuantity}" Width="90"/>
                <DataGridTextColumn Header="最低库存" Binding="{Binding MinStockLevel}" Width="90"/>
                <DataGridTextColumn Header="库存状态" Binding="{Binding StockStatus}" Width="100"/>
                <DataGridTextColumn Header="销售价" Binding="{Binding SalesPrice, StringFormat={}{0:F2}}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</Window>
