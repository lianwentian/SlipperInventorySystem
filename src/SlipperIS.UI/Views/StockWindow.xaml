<Window x:Class="SlipperIS.UI.Views.StockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="库存管理" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>

        <!-- 工具栏 -->
        <Border Grid.Row="0" Background="White" Margin="8,8,8,4" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <TextBlock Text="搜索：" VerticalAlignment="Center" Margin="0,0,4,0" Foreground="#555"/>
                <TextBox x:Name="SearchBox" Width="160" Height="28" Padding="4,2"
                         BorderBrush="#CCC" BorderThickness="1" VerticalContentAlignment="Center"
                         TextChanged="SearchBox_TextChanged"/>
                <CheckBox x:Name="ChkLowStock" Content="仅显示库存预警" Margin="16,0,0,0"
                          VerticalAlignment="Center" Checked="FilterChanged" Unchecked="FilterChanged"/>
                <Button Content="刷新" Margin="12,0,0,0" Padding="8,4"
                        Background="#2196F3" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="Refresh_Click"/>
            </StackPanel>
        </Border>

        <!-- 库存列表 -->
        <DataGrid x:Name="StockGrid" Grid.Row="1"
                  Margin="8,4" AutoGenerateColumns="False"
                  CanUserAddRows="False" IsReadOnly="True"
                  SelectionMode="Single" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" AlternatingRowBackground="#FAFAFA"
                  BorderBrush="#DDD" BorderThickness="1">
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsLowStock}" Value="True">
                            <Setter Property="Background" Value="#FFEBEE"/>
                            <Setter Property="Foreground" Value="#C62828"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
            <DataGrid.Columns>
                <DataGridTextColumn Header="产品编码" Binding="{Binding ProductCode}" Width="100"/>
                <DataGridTextColumn Header="产品名称" Binding="{Binding ProductName}" Width="160"/>
                <DataGridTextColumn Header="类别" Binding="{Binding Category}" Width="90"/>
                <DataGridTextColumn Header="规格" Binding="{Binding Specification}" Width="120"/>
                <DataGridTextColumn Header="当前库存" Binding="{Binding StockQuantity}" Width="90"/>
                <DataGridTextColumn Header="最低库存" Binding="{Binding MinStockLevel}" Width="90"/>
                <DataGridTextColumn Header="状态" Binding="{Binding StockStatus}" Width="90"/>
                <DataGridTextColumn Header="成本价" Binding="{Binding CostPrice, StringFormat=\{0:F2\}}" Width="80"/>
                <DataGridTextColumn Header="库存价值" Binding="{Binding StockValue, StringFormat=\{0:F2\}}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- 库存调整面板 -->
        <Border x:Name="AdjustPanel" Grid.Row="2" Visibility="Collapsed"
                Background="White" Margin="8,4" Padding="12"
                BorderBrush="#DDD" BorderThickness="1" CornerRadius="4">
            <StackPanel>
                <TextBlock Text="库存调整" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" Foreground="#333"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="4">
                        <TextBlock Text="产品" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtAdjProduct" Height="28" Padding="4,2" Margin="0,2,0,0"
                                 BorderBrush="#CCC" BorderThickness="1" IsReadOnly="True" Background="#F5F5F5"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Margin="4">
                        <TextBlock Text="调整类型" Foreground="#555" FontSize="11"/>
                        <ComboBox x:Name="CmbAdjType" Height="28" Margin="0,2,0,0" BorderBrush="#CCC" BorderThickness="1">
                            <ComboBoxItem Content="入库 (In)" IsSelected="True"/>
                            <ComboBoxItem Content="出库 (Out)"/>
                            <ComboBoxItem Content="调整 (Adjustment)"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Margin="4">
                        <TextBlock Text="数量" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtAdjQty" Height="28" Padding="4,2" Margin="0,2,0,0"
                                 BorderBrush="#CCC" BorderThickness="1" Text="0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" Margin="4">
                        <TextBlock Text="原因" Foreground="#555" FontSize="11"/>
                        <TextBox x:Name="TxtAdjReason" Height="28" Padding="4,2" Margin="0,2,0,0"
                                 BorderBrush="#CCC" BorderThickness="1"/>
                    </StackPanel>
                </Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
                    <Button Content="确认调整" Padding="16,6" Margin="0,0,8,0"
                            Background="#4CAF50" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="ConfirmAdjust_Click"/>
                    <Button Content="取消" Padding="16,6"
                            Background="#9E9E9E" Foreground="White" BorderThickness="0"
                            Cursor="Hand" Click="CancelAdjust_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 操作栏 -->
        <Border Grid.Row="3" Background="White" Margin="8,4,8,8" Padding="8,0" CornerRadius="4">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="📦 库存调整" Padding="12,6" Margin="0,0,8,0"
                        Background="#FF9800" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="AdjustStock_Click"/>
                <TextBlock x:Name="StatusText" VerticalAlignment="Center"
                           Margin="8,0,0,0" Foreground="#666" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
