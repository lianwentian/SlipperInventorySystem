<Window x:Class="SlipperIS.UI.Views.ProductImageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="产品图片预览" Height="600" Width="900"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：产品列表 -->
        <DockPanel Grid.Column="0">
            <Border DockPanel.Dock="Top" Background="#2196F3" Padding="10,5">
                <TextBlock Text="产品列表" Foreground="White" FontWeight="Bold"/>
            </Border>
            <ListBox x:Name="ProductList" SelectionChanged="ProductList_SelectionChanged"
                     DisplayMemberPath="ProductName"/>
        </DockPanel>

        <!-- 右侧：图片列表和预览 -->
        <DockPanel Grid.Column="1">
            <Border DockPanel.Dock="Top" Background="#37474F" Padding="10,5">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="产品图片" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="➕ 添加图片" Click="AddImage_Click" Background="#4CAF50" Foreground="White"
                            Padding="8,4" Margin="15,0,5,0" BorderThickness="0" Cursor="Hand"/>
                    <Button Content="🗑️ 删除图片" Click="DeleteImage_Click" Background="#F44336" Foreground="White"
                            Padding="8,4" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </Border>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="150"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 图片缩略图列表 -->
                <ListBox x:Name="ImageList" Grid.Row="0" Margin="5"
                         ScrollViewer.HorizontalScrollBarVisibility="Auto"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"
                         SelectionChanged="ImageList_SelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="5" Width="100">
                                <Border Width="90" Height="90" Background="#EEE" BorderBrush="#CCC" BorderThickness="1">
                                    <Image Source="{Binding ImagePath}" Stretch="Uniform"
                                           Width="88" Height="88"/>
                                </Border>
                                <TextBlock Text="{Binding ImageName}" TextTrimming="CharacterEllipsis"
                                           HorizontalAlignment="Center" FontSize="10" Margin="0,2,0,0"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <!-- 大图预览 -->
                <Border Grid.Row="1" Background="#F5F5F5" Margin="5" BorderBrush="#DDD" BorderThickness="1">
                    <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10"/>
                </Border>
            </Grid>
        </DockPanel>
    </Grid>
</Window>
